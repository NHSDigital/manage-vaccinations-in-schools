{
  "name": "Manage Vaccinations in Schools",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/manage-vaccinations-in-schools",

  // Forward the Falcon dev server port so VS Code opens it in the browser
  "forwardPorts": [4000],
  "portsAttributes": {
    "4000": {
      "label": "Rails web server",
      "onAutoForward": "notify"
    }
  },

  // Install gems, JS packages and prepare the database on first container
  // creation. Skips starting the dev server — run that manually with:
  //   foreman start -f Procfile.devcontainer
  "postCreateCommand": "bin/setup --skip-server",

  "remoteUser": "vscode",

  "customizations": {
    "vscode": {
      "extensions": [
        // Ruby
        "Shopify.ruby-lsp",
        "castwide.solargraph",
        // JS / CSS
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        // Git / GitHub
        "GitHub.vscode-pull-request-github",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        // Use the project's bundled solargraph / rubocop so they match the
        // Gemfile-locked versions
        "solargraph.useBundler": true,
        "rubyLsp.useBundlerCompose": true
      }
    }
  }
}
